# ============================================
# Self-hosted Ubuntu + Docker baseline
# ============================================

NODE_ENV="production"
WEB_PORT="3000"
POSTGRES_PORT="5432"

# PostgreSQL (docker-compose postgres service)
POSTGRES_DB="alles_inventory"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"

# Prisma connection (single source of truth = local postgres)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/alles_inventory"
DIRECT_URL="postgresql://postgres:postgres@postgres:5432/alles_inventory"

# Storage roots on server/container
DATA_ROOT="/data"
FILE_STORAGE_ROOT="/data/uploads"
DOCUMENTS_STORAGE_ROOT="/data/documents"
BACKUP_ROOT="/data/backups"
HOST_DATA_PATH="/data"

# Worker
WORKER_POLL_INTERVAL_MS="5000"

# Optional integrations
KOREAEXIM_API_KEY="sample"
PROXY_SERVER_URL=""

# Auth / seed
AUTH_SECRET="change-this-to-a-long-random-secret"
SEED_ADMIN_PASSWORD="ChangeMeAdmin!123"
SEED_STAFF_PASSWORD="ChangeMeStaff!123"
